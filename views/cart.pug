extends layouts/base.pug

block content
  main(class="max-w-container-max mx-auto px-margin-mobile md:px-margin-desktop py-12")
    div(class="grid grid-cols-1 lg:grid-cols-[1fr_400px] gap-12")

      //- ── LEFT: ARSENAL ITEMS ──
      section(class="space-y-8")
        header(class="border-b-2 border-primary pb-2 inline-block")
          h1(class="font-headline-lg text-[32px] text-white uppercase tracking-wider") YOUR ARSENAL

        div(class="space-y-4" id="cart-items-container")
          if cart && cart.items && cart.items.length
            each item in cart.items
              div(class="bg-[#111111] border border-[#1f1f1f] p-4 flex flex-col md:flex-row items-center gap-6 group transition-colors hover:border-primary/30")
                //- Product image
                div(class="w-20 h-20 bg-black flex-shrink-0 flex items-center justify-center border border-[#1f1f1f]")
                  if item.product && item.product.imageCover
                    img(
                      src=`/images/products/${item.product.imageCover}`
                      alt=item.product.name
                      class="w-16 h-16 object-contain"
                    )
                  else
                    span(class="material-symbols-outlined text-outline-variant") inventory_2

                //- Product Info
                div(class="flex-grow text-center md:text-left")
                  span(class="font-label-caps text-[10px] text-primary tracking-[0.2em]") #{item.productType.toUpperCase()}
                  h3(class="font-headline-md text-[18px] text-white leading-tight mt-1")
                    if item.product
                      | #{item.product.name}
                    else
                      | PRODUCT UNAVAILABLE

                //- Quantity
                div(class="flex items-center gap-4")
                  div(class="flex items-center border border-primary")
                    button(
                      class="qty-btn w-8 h-8 flex items-center justify-center text-primary hover:bg-primary hover:text-black transition-colors"
                      data-action="decrease"
                      data-id=(item.product && item.product._id)
                      data-type=item.productType
                    ) -
                    span(class="w-10 text-center font-accent-stat text-white") #{item.quantity < 10 ? '0' + item.quantity : item.quantity}
                    button(
                      class="qty-btn w-8 h-8 flex items-center justify-center text-primary hover:bg-primary hover:text-black transition-colors"
                      data-action="increase"
                      data-id=(item.product && item.product._id)
                      data-type=item.productType
                    ) +

                //- Line Price
                div(class="min-w-[100px] text-center md:text-right")
                  if item.product
                    span(class="font-accent-stat text-white text-lg") $#{(item.product.price * item.quantity).toFixed(2)}

                //- Delete
                button(
                  class="delete-item-btn text-red-500 hover:scale-125 transition-transform p-2"
                  data-id=item._id
                  data-type=item.productType
                )
                  span(class="material-symbols-outlined") delete

          else
            div(class="text-center py-20 bg-surface-container")
              span(class="material-symbols-outlined text-6xl text-outline-variant mb-4 block") shopping_bag
              p(class="text-on-surface-variant font-headline-md text-xl") YOUR ARSENAL IS EMPTY.
              a(href="/shop" class="inline-block mt-6 px-10 py-4 bg-primary text-on-primary font-label-caps hover:bg-[#FFAA00] transition-colors") BROWSE THE SHOP

        a(href="/shop" class="inline-flex items-center gap-2 text-primary font-label-caps hover:underline group")
          span(class="material-symbols-outlined group-hover:-translate-x-1 transition-transform") arrow_back
          | CONTINUE SHOPPING

      //- ── RIGHT: ORDER SUMMARY ──
      aside
        div(class="bg-[#111111] border-t-2 border-primary p-8 sticky top-32")
          h2(class="font-headline-md text-primary text-2xl uppercase tracking-widest mb-8") ORDER SUMMARY
          div(class="space-y-4 font-body-md")
            div(class="flex justify-between")
              span(class="text-[#555555] uppercase text-xs tracking-widest") SUBTOTAL
              span(class="text-white font-accent-stat") $#{totalPrice.toFixed(2)}
            div(class="flex justify-between")
              span(class="text-[#555555] uppercase text-xs tracking-widest") SHIPPING
              span(class="text-green-400 font-accent-stat") FREE
            div(class="border-t-4 border-primary pt-6 flex justify-between items-end mb-8")
              span(class="font-headline-md text-white text-xl") TOTAL
              span(class="font-accent-stat text-primary text-3xl font-bold") $#{totalPrice.toFixed(2)}

            if cart && cart.items && cart.items.length
              a(href="/checkout" class="w-full h-[56px] bg-primary text-black font-headline-md text-xl font-bold uppercase tracking-widest hover:bg-white hover:text-black transition-all active:scale-95 flex items-center justify-center gap-3")
                | PROCEED TO CHECKOUT
                span(class="material-symbols-outlined") bolt
            else
              button(disabled class="w-full h-[56px] bg-surface-variant text-on-secondary-container font-headline-md text-xl uppercase cursor-not-allowed flex items-center justify-center")
                | ARSENAL IS EMPTY

          div(class="mt-8 space-y-4")
            div(class="flex items-center gap-4 text-[#555555]")
              span(class="material-symbols-outlined text-green-500") lock
              span(class="font-label-caps text-[10px]") 256-BIT SSL ENCRYPTED CONNECTION
            div(class="flex items-center gap-4 text-[#555555]")
              span(class="material-symbols-outlined text-primary") verified_user
              span(class="font-label-caps text-[10px]") SECURE PAYMENT GUARANTEED

block scripts
  script.
    document.querySelectorAll('.qty-btn').forEach(btn => {
      btn.addEventListener('click', async (e) => {
        const productId = e.currentTarget.dataset.id;
        const productType = e.currentTarget.dataset.type;
        const action = e.currentTarget.dataset.action;
        if (!productId) return;
        try {
          const res = await fetch('/api/v1/carts', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
              product: productId,
              productType: productType,
              quantity: action === 'increase' ? 1 : -1
            })
          });
          if (res.ok) window.location.reload();
        } catch(err) { console.error(err); }
      });
    });

    document.querySelectorAll('.delete-item-btn').forEach(btn => {
      btn.addEventListener('click', async (e) => {
        const itemId = e.currentTarget.dataset.id;
        if (!itemId) return;
        try {
          const res = await fetch(`/api/v1/carts/item/${itemId}`, { method: 'DELETE' });
          if (res.ok) window.location.reload();
        } catch(err) { console.error(err); }
      });
    });
