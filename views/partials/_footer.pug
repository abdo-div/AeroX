footer(class="bg-surface-container-lowest py-16 px-margin-mobile md:px-margin-desktop border-t-2 border-primary")
  div(class="grid grid-cols-1 md:grid-cols-4 gap-gutter mb-16 max-w-container-max mx-auto")

    //- Brand column
    div(class="col-span-1")
      a(href="/" class="flex items-center mb-6 shrink-0")
        img(src="/images/logo.png" alt="AeroX Kinetic Armory" style="width:14rem;height:auto" class="object-contain")
      p(class="text-on-secondary-container font-body-md mb-8") Forged for professionals, engineered for the absolute elite. The future of gaming starts here.
      div(class="flex gap-4")
        a(href="#" class="material-symbols-outlined text-on-surface hover:text-primary transition-colors" aria-label="Share") share
        a(href="#" class="material-symbols-outlined text-on-surface hover:text-primary transition-colors" aria-label="YouTube") videocam
        a(href="#" class="material-symbols-outlined text-on-surface hover:text-primary transition-colors" aria-label="Discord") forum

    //- Products column
    div
      h5(class="font-label-caps text-label-caps text-primary mb-8 uppercase") Products
      ul(class="space-y-4")
        li: a(href="/shop?category=keyboard" class="font-body-md text-on-secondary-container hover:text-primary transition-colors") Keyboards
        li: a(href="/shop?category=mouse" class="font-body-md text-on-secondary-container hover:text-primary transition-colors") Mice
        li: a(href="/shop?category=audio" class="font-body-md text-on-secondary-container hover:text-primary transition-colors") Audio
        li: a(href="/shop?category=streaming" class="font-body-md text-on-secondary-container hover:text-primary transition-colors") Streaming
        li: a(href="/shop?category=ambient-lighting" class="font-body-md text-on-secondary-container hover:text-primary transition-colors") Lighting

    //- Support column
    div
      h5(class="font-label-caps text-label-caps text-primary mb-8 uppercase") Support
      ul(class="space-y-4")
        li: a(href="#" class="font-body-md text-on-secondary-container hover:text-primary transition-colors") Support Center
        li: a(href="#" class="font-body-md text-on-secondary-container hover:text-primary transition-colors") Warranty
        li: a(href="#" class="font-body-md text-on-secondary-container hover:text-primary transition-colors") Shipping
        li: a(href="#" class="font-body-md text-on-secondary-container hover:text-primary transition-colors") Contact

    //- Community column
    div
      h5(class="font-label-caps text-label-caps text-primary mb-8 uppercase") Community
      ul(class="space-y-4")
        li: a(href="#" class="font-body-md text-on-secondary-container hover:text-primary transition-colors") Twitter
        li: a(href="#" class="font-body-md text-on-secondary-container hover:text-primary transition-colors") YouTube
        li: a(href="#" class="font-body-md text-on-secondary-container hover:text-primary transition-colors") Instagram
        li: a(href="#" class="font-body-md text-on-secondary-container hover:text-primary transition-colors") Discord

  //- Bottom bar
  div(class="flex flex-col md:flex-row justify-between items-center pt-8 border-t border-surface-variant max-w-container-max mx-auto")
    span(class="font-label-caps text-[10px] text-on-secondary-container mb-4 md:mb-0") © 2024 AEROX. ENGINEERED FOR DOMINANCE.
    div(class="flex gap-8")
      a(href="#" class="font-label-caps text-[10px] text-on-secondary-container hover:text-primary") PRIVACY POLICY
      a(href="#" class="font-label-caps text-[10px] text-on-secondary-container hover:text-primary") TERMS OF SERVICE
      a(href="#" class="font-label-caps text-[10px] text-on-secondary-container hover:text-primary") COOKIE SETTINGS
