extends layouts/base.pug

block content
  main(class="max-w-container-max mx-auto px-margin-mobile md:px-margin-desktop py-12 flex flex-col md:flex-row gap-gutter")
    //- ── SIDEBAR ──
    aside(class="w-full md:w-[260px] shrink-0 space-y-2")
      a(href="/me" class="flex items-center gap-4 px-6 py-4 border-l-2 border-primary bg-surface-container text-primary active-glow transition-all")
        span(class="material-symbols-outlined") account_circle
        span(class="font-label-caps text-label-caps") PERSONAL INFO
      a(href="/my-orders" class="flex items-center gap-4 px-6 py-4 border-l-2 border-transparent text-on-surface-variant hover:bg-surface-container transition-all")
        span(class="material-symbols-outlined") shopping_bag
        span(class="font-label-caps text-label-caps") MY ORDERS

    //- ── MAIN CONTENT ──
    section(class="flex-1 min-w-0")
      div(class="mb-12")
        h1(class="font-headline-lg text-headline-lg text-primary mb-2") PROFILE SETTINGS
        div(class="h-1 w-24 bg-primary")

      div(class="grid grid-cols-1 md:grid-cols-3 gap-12")
        //- Avatar Upload
        div(class="md:col-span-1")
          h3(class="font-label-caps text-on-surface-variant mb-4") PROFILE PHOTO
          div(
            id="avatar-container"
            class="aspect-square border-2 border-dashed border-primary/30 bg-surface-container-low flex flex-col items-center justify-center cursor-pointer hover:bg-surface-container transition-all group relative overflow-hidden"
          )
            if user.photo && user.photo !== 'default-userInfo.jpg'
              img(src=`/images/users/${user.photo}` alt="Profile photo" class="w-full h-full object-cover absolute inset-0")
            else
              span(class="material-symbols-outlined text-5xl text-primary/50 group-hover:text-primary transition-all mb-2") person
              p(class="font-label-caps text-[10px] text-on-surface-variant text-center px-2") #{user.name.toUpperCase()}
            div(class="absolute inset-0 bg-black/60 opacity-0 group-hover:opacity-100 transition-opacity flex items-center justify-center")
              span(class="material-symbols-outlined text-primary text-3xl") add_a_photo
          input(type="file" id="avatar-input" accept="image/*" class="hidden")
          div(id="avatar-actions" class="mt-3 hidden flex gap-2")
            button(id="avatar-upload-btn" type="button" class="flex-1 bg-primary text-on-primary font-label-caps text-[11px] py-2 hover:bg-[#FFAA00] transition-all") UPLOAD
            button(id="avatar-cancel-btn" type="button" class="flex-1 border border-outline-variant text-on-surface-variant font-label-caps text-[11px] py-2 hover:bg-surface-container transition-all") CANCEL

        //- Profile Form
        div(class="md:col-span-2 space-y-8")
          form(id="profile-form" class="space-y-6")
            div(class="grid grid-cols-1 md:grid-cols-2 gap-6")
              div(class="space-y-2")
                label(class="font-label-caps text-on-surface-variant block") OPERATOR NAME
                input(
                  type="text"
                  id="profile-name"
                  class="w-full bg-background border border-outline-variant focus:border-primary text-primary px-4 py-3 outline-none transition-all"
                  value=user.name
                )
              div(class="space-y-2")
                label(class="font-label-caps text-on-surface-variant block") EMAIL ADDRESS
                input(
                  type="email"
                  id="profile-email"
                  class="w-full bg-background border border-outline-variant focus:border-primary text-primary px-4 py-3 outline-none transition-all"
                  value=user.email
                )
            button(type="submit" class="bg-primary text-on-primary font-label-caps text-label-caps px-10 py-4 font-bold hover:bg-[#FFAA00] transition-all active:scale-95")
              | SAVE CHANGES

          //- System Info Strip
          div(class="mt-12 pt-8 border-t border-surface-variant grid grid-cols-2 gap-4")
            div
              p(class="font-label-caps text-[10px] text-on-surface-variant") SYSTEM ROLE
              p(class="font-headline-md text-primary") #{user.role.toUpperCase()}
            div
              p(class="font-label-caps text-[10px] text-on-surface-variant") ACCOUNT STATUS
              div(class="flex items-center gap-2 mt-1")
                span(class="w-2 h-2 bg-green-500 rounded-full animate-pulse")
                span(class="font-label-caps text-[10px] text-green-400") ACTIVE

          //- Logout
          div(class="pt-6")
            button(id="logout-btn" class="flex items-center gap-3 px-8 py-4 text-error hover:bg-error/10 border border-error/30 hover:border-error transition-all")
              span(class="material-symbols-outlined") logout
              span(class="font-label-caps text-label-caps") TERMINATE SESSION

block scripts
  script.
    document.getElementById('logout-btn').addEventListener('click', async () => {
      try {
        const res = await fetch('/api/v1/users/logout', { method: 'GET' });
        if (res.ok) window.location.href = '/';
      } catch(err) { console.error(err); }
    });

    document.getElementById('profile-form').addEventListener('submit', async (e) => {
      e.preventDefault();
      const name = document.getElementById('profile-name').value;
      const email = document.getElementById('profile-email').value;
      try {
        const res = await fetch('/api/v1/users/updateMe', {
          method: 'PATCH',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ name, email })
        });
        const data = await res.json();
        if (res.ok) {
          alert('Profile updated successfully.');
          window.location.reload();
        } else {
          alert(data.message || 'Update failed.');
        }
      } catch(err) { console.error(err); }
    });

    const avatarContainer = document.getElementById('avatar-container');
    const avatarInput = document.getElementById('avatar-input');
    const avatarActions = document.getElementById('avatar-actions');
    const avatarUploadBtn = document.getElementById('avatar-upload-btn');
    const avatarCancelBtn = document.getElementById('avatar-cancel-btn');
    let selectedFile = null;

    if (avatarContainer && avatarInput) {
      avatarContainer.addEventListener('click', () => avatarInput.click());

      avatarInput.addEventListener('change', (e) => {
        selectedFile = e.target.files[0];
        if (!selectedFile) return;
        const reader = new FileReader();
        reader.onload = (ev) => {
          avatarContainer.innerHTML = `<img src="${ev.target.result}" alt="Preview" class="w-full h-full object-cover absolute inset-0"><div class="absolute inset-0 bg-black/60 opacity-100 flex items-center justify-center"><span class="material-symbols-outlined text-primary text-3xl">add_a_photo</span></div>`;
        };
        reader.readAsDataURL(selectedFile);
        avatarActions.classList.remove('hidden');
      });

      if (avatarUploadBtn) {
        avatarUploadBtn.addEventListener('click', async () => {
          if (!selectedFile) return;
          const formData = new FormData();
          formData.append('photo', selectedFile);
          try {
            avatarUploadBtn.textContent = 'UPLOADING...';
            const res = await fetch('/api/v1/users/updateMe', {
              method: 'PATCH',
              body: formData,
            });
            const data = await res.json();
            if (res.ok) {
              window.location.reload();
            } else {
              alert(data.message || 'Upload failed.');
              avatarUploadBtn.textContent = 'UPLOAD';
            }
          } catch(err) { console.error(err); }
        });
      }

      if (avatarCancelBtn) {
        avatarCancelBtn.addEventListener('click', () => {
          selectedFile = null;
          avatarInput.value = '';
          avatarActions.classList.add('hidden');
          window.location.reload();
        });
      }
    }
