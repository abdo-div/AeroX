  body(class="bg-background text-on-surface custom-scrollbar overflow-x-hidden")

    //- Flash Alert Messages
    if locals.alert
      .alert(class=`alert--${alertType || 'success'}`) #{alert}

    //- Header Partial
    include ../partials/_header.pug

    //- Page Content
    block content

    //- Footer Partial
    include ../partials/_footer.pug

    //- Global JS
    script.
      // Scroll reveal animation
      const revealObserver = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) entry.target.classList.add('active');
        });
      }, { threshold: 0.1 });
      document.querySelectorAll('.reveal').forEach(el => revealObserver.observe(el));

      // Sticky Navbar shrink on scroll
      window.addEventListener('scroll', () => {
        const nav = document.querySelector('nav#main-nav');
        if (!nav) return;
        if (window.scrollY > 50) {
          nav.style.height = '5rem';
        } else {
          nav.style.height = '6rem';
        }
      });

      // Auto-dismiss alerts
      const alertEl = document.querySelector('.alert');
      if (alertEl) setTimeout(() => alertEl.remove(), 5000);

      // Google Sign-In callback
      async function handleGoogleCredential(response) {
        try {
          const res = await fetch('/api/v1/users/auth/google', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ idToken: response.credential })
          });
          const data = await res.json();
          if (res.ok) {
            window.location.href = '/';
          } else {
            alert(data.message || 'Google authentication failed.');
          }
        } catch(err) {
          console.error(err);
          alert('Connection error. Try again.');
        }
      }

      // Live cart badge updater
      async function updateCartBadge() {
        try {
          const res = await fetch('/api/v1/carts');
          if (!res.ok) return;
          const data = await res.json();
          const items = data.data.cart.items || [];
          const count = items.reduce((sum, i) => sum + i.quantity, 0);
          const badge = document.getElementById('nav-cart-badge');
          if (!badge) return;
          if (count > 0) {
            badge.textContent = count;
            badge.classList.remove('hidden');
            badge.classList.add('absolute', '-top-2', '-right-2', 'w-4', 'h-4', 'bg-primary', 'text-on-primary', 'text-[9px]', 'font-black', 'flex', 'items-center', 'justify-center', 'rounded-full');
          } else {
            badge.classList.add('hidden');
          }
        } catch(err) {}
      }

    block scripts
