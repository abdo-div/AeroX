extends layouts/base.pug

block content
  main(class="max-w-container-max mx-auto px-margin-mobile md:px-margin-desktop py-20 flex items-center justify-center min-h-[60vh]")
    div(class="text-center max-w-md")
      div(class="w-20 h-20 bg-green-500/10 border-2 border-green-500 rounded-full flex items-center justify-center mx-auto mb-8")
        span(class="material-symbols-outlined text-green-500 text-5xl" style="font-variation-settings: 'FILL' 1;") check_circle
      h1(class="font-headline-lg text-headline-lg text-primary mb-4") ORDER CONFIRMED
      p(class="text-on-surface-variant font-body-md mb-8") Your deployment has been logged. Payment has been processed securely via Stripe.
      div(class="flex gap-4 justify-center")
        a(href="/my-orders" class="bg-primary text-on-primary font-label-caps text-label-caps px-8 py-3 font-bold hover:bg-[#FFAA00] transition-all active:scale-95") VIEW ORDERS
        a(href="/shop" class="border border-outline-variant text-on-surface-variant font-label-caps text-label-caps px-8 py-3 hover:bg-surface-container transition-all") CONTINUE SHOPPING
