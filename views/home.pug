        div(class="h-1 w-32 bg-primary")
      a(href="/shop" class="font-label-caps text-label-caps text-primary hover:underline") VIEW ALL COLLECTION

    div(class="grid grid-cols-1 md:grid-cols-4 gap-gutter")
