          div(class="reveal bg-surface border border-surface-variant rgb-border-top p-6 group")
            div(class="aspect-square mb-6 overflow-hidden bg-surface-container-high relative")
              img(class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500" src=item.img alt=item.name)
