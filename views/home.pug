                span(class="absolute top-4 left-4 bg-primary text-on-primary text-[10px] px-2 py-1 font-label-caps") #{item.tag}
            div(class="flex justify-between items-start mb-4")
              div
                h4(class="font-headline-md text-body-md uppercase text-on-surface") #{item.name}
                p(class="font-label-caps text-[10px] text-on-surface-variant") #{item.cat}
              span(class="font-accent-stat text-primary") #{item.price}
            button(class="w-full py-3 border border-on-surface hover:bg-primary hover:text-on-primary hover:border-primary transition-all font-label-caps text-[10px]") ADD TO ARSENAL

  //- ── WHY AEROX ──────────────────────────────────────────────────────────────
  -
    var features = [
      {icon:'bolt', title:'Ultra-Low Latency', desc:'Engineered with our proprietary 0.2ms optical tech for instantaneous execution.'},
      {icon:'verified_user', title:'2-Year Warranty', desc:'We stand behind every build. Full coverage for 24 months of relentless play.'},
      {icon:'public', title:'Global Shipping', desc:'Dominance knows no borders. Expedited delivery to any battlefield worldwide.'},
      {icon:'psychology', title:'iAero Software', desc:'Advanced customization and macros through our intuitive cloud-synced dashboard.'}
    ]
  section(class="px-margin-mobile md:px-margin-desktop py-24")
    div(class="grid grid-cols-1 md:grid-cols-4 gap-gutter reveal")
      each feat in features
