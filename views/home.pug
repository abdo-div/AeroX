  //- ── CATEGORY STRIP ─────────────────────────────────────────────────────────
  section(class="relative z-20 -mt-16 md:-mt-24 px-margin-mobile md:px-margin-desktop mb-24 reveal")
    div(class="grid grid-cols-2 md:grid-cols-5 gap-4")
      each cat in [{icon:'keyboard',label:'Keyboards',slug:'keyboard'},{icon:'mouse',label:'Mice',slug:'mouse'},{icon:'headphones',label:'Audio',slug:'audio'},{icon:'videocam',label:'Streaming',slug:'streaming'},{icon:'lightbulb',label:'Lighting',slug:'ambient-lighting'}]
