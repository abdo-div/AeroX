          | DOMINATE.
          br
          | EVERY.
          br
          | MATCH.
        div(class="flex flex-col sm:flex-row gap-4 mb-12")
          a(href="/shop" class="px-10 py-4 bg-primary text-on-primary font-label-caps text-label-caps hover:bg-[#FFAA00] transition-colors text-center") SHOP NOW
          a(href="/shop" class="px-10 py-4 border-2 border-on-surface text-on-surface font-label-caps text-label-caps hover:bg-on-surface hover:text-background transition-all text-center") EXPLORE LINEUP

        //- Stats strip
        div(class="grid grid-cols-2 md:grid-cols-3 gap-8 pt-8 border-t border-surface-variant")
          div
            div(class="font-accent-stat text-accent-stat text-primary") 0.2ms
            div(class="font-label-caps text-[10px] text-on-surface-variant") LATENCY
          div
            div(class="font-accent-stat text-accent-stat text-primary") 8000Hz
            div(class="font-label-caps text-[10px] text-on-surface-variant") POLLING RATE
