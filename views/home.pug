          span(class="material-symbols-outlined text-primary text-5xl mb-6 block") #{feat.icon}
          h4(class="font-headline-md text-headline-md uppercase mb-4") #{feat.title}
          p(class="text-on-surface-variant font-body-md") #{feat.desc}
          p(class="text-on-surface-variant font-body-md") #{feat.desc}

  //- ── NEWSLETTER ─────────────────────────────────────────────────────────────
  section(class="px-margin-mobile md:px-margin-desktop py-32 relative overflow-hidden bg-primary")
    div(class="absolute inset-0 opacity-10 pointer-events-none")
