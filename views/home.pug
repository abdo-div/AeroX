        button(id="newsletter-btn" class="bg-background text-primary px-12 py-6 font-label-caps text-label-caps hover:bg-surface-variant hover:text-on-surface transition-colors") SUBSCRIBE

block scripts
  script.
    // Add to cart from homepage
    document.querySelectorAll('.add-to-cart-btn').forEach(btn => {
      btn.addEventListener('click', async (e) => {
        e.preventDefault();
        e.stopPropagation();
        const id = e.currentTarget.dataset.id;
        if (!id) return;
        try {
          const res = await fetch('/api/v1/carts', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            credentials: 'include',
            body: JSON.stringify({ product: id, quantity: 1 })
          });
          const data = await res.json();
          if (res.ok) {
            e.target.textContent = '✓ ADDED';
            e.target.classList.replace('border-on-surface', 'border-primary');
            e.target.classList.add('bg-primary', 'text-on-primary');
          }
        } catch(err) { console.error(err); }
      });
    });
